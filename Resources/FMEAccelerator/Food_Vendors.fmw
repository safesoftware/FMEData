FACTORY_DEF * TeeFactory    FACTORY_NAME "road-ahead-upcoming-projects_SHAPEFILE_2 Splitter"    INPUT FEATURE_TYPE road-ahead-upcoming-projects    OUTPUT FEATURE_TYPE road-ahead-upcoming-projects_SHAPEFILE_2
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "public.business-licences_POSTGRES_1 Splitter"    INPUT FEATURE_TYPE public.business-licences    OUTPUT FEATURE_TYPE public.business-licences_POSTGRES_1
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "CSV_CSV2_1 Splitter"    INPUT FEATURE_TYPE CSV    OUTPUT FEATURE_TYPE CSV_CSV2_1_0_yvsMpFt/4Gw=    OUTPUT FEATURE_TYPE CSV_CSV2_1_1_GVR6dhZPGYA=
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester }    INPUT  FEATURE_TYPE public.business-licences_POSTGRES_1    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>status<closeparen>,Tester)" != Gone<space>Out<space>of<space>Business ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>businesstype<closeparen>,Tester)" = Street<space>Vendor ENCODED }    BOOLEAN_OPERATOR { COMPOSITE }    COMPOSITE_TEST_EXPR { "1 AND 2" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE Tester_PASSED         }
# -------------------------------------------------------------------------
MACRO testClauses #Tcl to generate test clauses for the table in preparation for the TestFactory
#Each Attribute gets put in a seperate clause
INCLUDE [    set table {KEY$ATTRIBUTE_UNIQUE$<Unused>/BUSINESS_NAME$ATTRIBUTE_HAS_A_VALUE$<Unused>};    set testString {MACRO testClauses };    set rows [split $table {/}];    foreach row $rows {    set cells [split $row {$}];    set attrs [split [lindex $cells 0] {,}];       set op [lindex $cells 1];       set val [lindex $cells 2];       foreach attr $attrs {           append testString "TEST \{ ${attr} ${op} ${val} ENCODED \} ";       };    };    puts $testString;    ]
FACTORY_DEF {*} TestFactory    FACTORY_NAME { AttributeValidator }    INPUT  FEATURE_TYPE CSV_CSV2_1_0_yvsMpFt/4Gw=    $(testClauses)    BOOLEAN_OPERATOR AND    VALIDATOR_MODE TRUE    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE AttributeValidator_PASSED         }
# -------------------------------------------------------------------------
# 20210313 - Use Macros to engage/disengage the solid vs. 2d buffering rather than a runtime
# check to reduce processing overhead
INCLUDE [if { ("JOIN_ARC" == "JOIN_MITER") } {         } else {             puts "MACRO MITER_TO_USE 0"         };         if { ("AREA" == "SOLID") } {             puts "MACRO SOLIDFACTORYENGAGED *";             puts "MACRO DISSOLVEFACTORYENGAGED NO";         } else {             puts "MACRO SOLIDFACTORYENGAGED NO";             puts "MACRO DISSOLVEFACTORYENGAGED *";         };         ]
#
# This is the AREA part of the buffering:
#
FACTORY_DEF {$(DISSOLVEFACTORYENGAGED)} PolygonDissolveFactory    FACTORY_NAME { Bufferer_2DBuffering }    INPUT  FEATURE_TYPE road-ahead-upcoming-projects_SHAPEFILE_2    FLUSH_WHEN_GROUPS_CHANGE { No }    REJECT_INVALID_GEOM Yes    USE_AZMED_NEIGHBORHOOD Yes    PRE_BUFFER { "@EvaluateExpression(FDIV,FLOAT,$(OFFSET$encode),Bufferer)" "22.5" "CAP_ARC" "JOIN_ARC" "$(MITER_TO_USE)" FULL OFFSET_UNITS "FEET" PRECISION "APPROX" }    DISSOLVE_MODE GEOS    CLEANING_TOLERANCE { AUTO }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    OUTPUT { POLYGON FEATURE_TYPE Bufferer_BUFFERED         }    OUTPUT { NON_POLYGON FEATURE_TYPE Bufferer_BUFFERED         }
#
# This is the SOLID part of the buffering:
#
FACTORY_DEF {$(SOLIDFACTORYENGAGED)} SolidBufferingFactory    FACTORY_NAME { Bufferer_3DBuffering }    INPUT  FEATURE_TYPE road-ahead-upcoming-projects_SHAPEFILE_2    SPHERE_RADIUS { "@EvaluateExpression(FDIV,FLOAT,$(OFFSET$encode),Bufferer)" }    SPHERE_DIVISIONS { "<Unused>" }    OUTPUT { BUFFERED FEATURE_TYPE Bufferer_BUFFERED        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} SpatialFilterFactory    FACTORY_NAME { SpatialFilter }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT BASE FEATURE_TYPE Bufferer_BUFFERED    INPUT CANDIDATE FEATURE_TYPE AttributeValidator_PASSED    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    PREDICATE { "INTERSECTS" }    USE_BOUNDING_BOX { NO }    MULTIPLE_BASES { YES }    MERGE_BASE_ATTR { YES }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "CANDIDATE_IF_CONFLICT" }    BASE_ATTR_PREFIX { "<Unused>" }    PREDICATE_ATTR { "_predicate" }    BOOLEAN_OPERATOR { OR }    REJECT_INVALID_GEOM Yes    REJECT_INVALID_PREDICATES Yes    REJECT_RASTERS No    REJECT_IGNORED_FILTER_FEATURES Yes    ALLOW_NULLS Yes    CUSTOM_MULTI_HANDLING { Yes }    DIMENSION 2    FLUSH_WHEN_GROUPS_CHANGE { <Unused>  }    CURVE_BOUNDARY_RULE { ENDPOINTS_MOD2 }    OUTPUT { PASSED FEATURE_TYPE SpatialFilter_PASSED         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} FeatureJoinerFactory    FACTORY_NAME { FeatureJoiner }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT LEFT FEATURE_TYPE SpatialFilter_PASSED    INPUT RIGHT FEATURE_TYPE Tester_PASSED    JOIN_MODE { Inner }    JOIN_KEYS { BUSINESS_NAME businesstradename AUTO }    ATTR_CONFLICT_RES { USE_LEFT }    PRESERVE_VALUES_FROM_UNJOINED_FEATURES { YES }    GEOMETRY_HANDLING { USE_LEFT }    OUTPUT { JOINED FEATURE_TYPE FeatureJoiner_JOINED        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { AttributeManager }    INPUT  FEATURE_TYPE FeatureJoiner_JOINED    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ACTION_COLUMN 4    DEF_VAL_COLUMN 2    NUM_OF_COLUMNS 5    MISSING_INPUT_ATTR_HANDLING RENAME_SET_VALUE REMOVE    ATTR_ACTION { "BUSINESS_NAME" "Business<space>Name" "" "varchar<openparen>29<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "VENDOR_TYPE" "VENDOR_TYPE" "" "varchar<openparen>12<closeparen>" "REMOVE" }      ATTR_ACTION { "DESCRIPTION" "Description" "" "varchar<openparen>35<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "LOCATION" "Location" "" "varchar<openparen>76<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "STATUS" "Status" "" "varchar<openparen>5<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "project" "Street<space>Project" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "street" "Street" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "location" "Location" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "comp_date" "Completion<space>Date" "" "date" "RENAME_SET_VALUE" }      ATTR_ACTION { "url_link" "Project<space>Information<space>Link" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "KEY" "KEY" "" "varchar<openparen>5<closeparen>" "REMOVE" }      ATTR_ACTION { "GEO_LOCALAREA" "GEO_LOCALAREA" "" "varchar<openparen>25<closeparen>" "REMOVE" }      ATTR_ACTION { "_predicate" "_predicate" "" "buffer" "REMOVE" }      ATTR_ACTION { "x" "x" "" "real64" "REMOVE" }      ATTR_ACTION { "y" "y" "" "real64" "REMOVE" }      ATTR_ACTION { "folderyear" "folderyear" "" "buffer" "REMOVE" }      ATTR_ACTION { "licencersn" "licencersn" "" "buffer" "REMOVE" }      ATTR_ACTION { "licencenumber" "Business<space>License<space>Number" "" "buffer" "RENAME_SET_VALUE" }      ATTR_ACTION { "licencerevisionnumber" "licencerevisionnumber" "" "buffer" "REMOVE" }      ATTR_ACTION { "businessname" "businessname" "" "buffer" "REMOVE" }      ATTR_ACTION { "businesstradename" "businesstradename" "" "buffer" "REMOVE" }      ATTR_ACTION { "status" "status" "" "buffer" "REMOVE" }      ATTR_ACTION { "issueddate" "issueddate" "" "datetime" "REMOVE" }      ATTR_ACTION { "expireddate" "expireddate" "" "date" "REMOVE" }      ATTR_ACTION { "businesstype" "businesstype" "" "buffer" "REMOVE" }      ATTR_ACTION { "businesssubtype" "businesssubtype" "" "buffer" "REMOVE" }      ATTR_ACTION { "unit" "unit" "" "buffer" "REMOVE" }      ATTR_ACTION { "unittype" "unittype" "" "buffer" "REMOVE" }      ATTR_ACTION { "house" "house" "" "buffer" "REMOVE" }      ATTR_ACTION { "city" "city" "" "buffer" "REMOVE" }      ATTR_ACTION { "province" "province" "" "buffer" "REMOVE" }      ATTR_ACTION { "country" "country" "" "buffer" "REMOVE" }      ATTR_ACTION { "postalcode" "postalcode" "" "buffer" "REMOVE" }      ATTR_ACTION { "localarea" "localarea" "" "buffer" "REMOVE" }      ATTR_ACTION { "numberofemployees" "numberofemployees" "" "real64" "REMOVE" }      ATTR_ACTION { "feepaid" "feepaid" "" "real64" "REMOVE" }      ATTR_ACTION { "extractdate" "extractdate" "" "datetime" "REMOVE" }      ATTR_ACTION { "" "email" "<at>LowerCase<openparen><at>ReplaceString<openparen><at>Value<openparen>Business<space>Name<closeparen><comma><quote><space><quote><comma><quote><quote><closeparen><closeparen><at>example.com" "varchar<openparen>200<closeparen>" "SET_TO" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeManager_OUTPUT        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester_auth }    INPUT  FEATURE_TYPE AttributeManager_OUTPUT    CASE_INSENSITIVE_TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,$(Auth$encode),Tester_auth)" BEGINS_WITH sk-proj ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE Tester_auth_PASSED         }
