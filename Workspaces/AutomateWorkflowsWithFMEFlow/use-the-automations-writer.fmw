SPATIALITE_NATIVE_1_DEF_TEMPLATE building_footprints   db_type                      {FME_FIRST_ENCOUNTERED_GEOMETRY}   fme_feature_operation        INSERT   fme_table_handling           CREATE_IF_MISSING   sqlite3_srid                 ""   sqlite3_dimension            AUTO   sqlite3_create_spatial_index YES   sqlite3_spatial_column_name  ""   sqlite3_compress_geometry    NO   fme_constant_feature_type    YES   fme_schema_feature_first     no   fme_geometry_name:geom       spatial_type,   id                           double   orient8                      double   bldgid                       real(20,0)   topelev_m                    double   med_slope                    real(20,0)   baseelev_m                   double   hgt_agl                      double   rooftype                     varchar(254)   area_m2                      double   avght_m                      double   minht_m                      double   maxht_m                      double   base_m                       double   len                          double   wid                          double
