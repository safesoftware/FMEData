DEFAULT_MACRO SPATIALITE_NATIVE_OUT_ALWAYS_CREATE_FEATURE_TYPES_SPATIALITE_NATIVE_1 NO
SPATIALITE_NATIVE_1_ALWAYS_CREATE_FEATURE_TYPES "$(SPATIALITE_NATIVE_OUT_ALWAYS_CREATE_FEATURE_TYPES_SPATIALITE_NATIVE_1)"
GUI LOOKUP_CHOICE SPATIALITE_NATIVE_OUT_ALWAYS_CREATE_FEATURE_TYPES_SPATIALITE_NATIVE_1 YES,YES%NO,NO Always Create Tables
# ============================================================================
# This keyword sets the number of features between transaction commits
DEFAULT_MACRO SPATIALITE_NATIVE_OUT_TRANSACTION_INTERVAL_SPATIALITE_NATIVE_1 500
SPATIALITE_NATIVE_1_TRANSACTION_INTERVAL "$(SPATIALITE_NATIVE_OUT_TRANSACTION_INTERVAL_SPATIALITE_NATIVE_1)"
GUI OPTIONAL TEXT SPATIALITE_NATIVE_OUT_TRANSACTION_INTERVAL_SPATIALITE_NATIVE_1 Features Per Transaction
# ============================================================================
# The following specifies an SQL command to execute before opening the first
# table.
DEFAULT_MACRO SPATIALITE_NATIVE_OUT_BEGIN_SQL{0}_SPATIALITE_NATIVE_1 
SPATIALITE_NATIVE_1_BEGIN_SQL{0} "$(SPATIALITE_NATIVE_OUT_BEGIN_SQL{0}_SPATIALITE_NATIVE_1)"
GUI OPTIONAL TEXT_EDIT_SQL_CFG SPATIALITE_NATIVE_OUT_BEGIN_SQL{0}_SPATIALITE_NATIVE_1 MODE,SQL;FORMAT,SPATIALITE_NATIVE SQL To Run Before Write
# ============================================================================
# The following specifies an SQL command to execute after closing all the
# tables.
DEFAULT_MACRO SPATIALITE_NATIVE_OUT_END_SQL{0}_SPATIALITE_NATIVE_1 
SPATIALITE_NATIVE_1_END_SQL{0} "$(SPATIALITE_NATIVE_OUT_END_SQL{0}_SPATIALITE_NATIVE_1)"
GUI OPTIONAL TEXT_EDIT_SQL_CFG SPATIALITE_NATIVE_OUT_END_SQL{0}_SPATIALITE_NATIVE_1 MODE,SQL;FORMAT,SPATIALITE_NATIVE SQL To Run After Write
# ============================================================================
# Prevent the infrastructure from reprojecting incoming features
DEFAULT_MACRO SPATIALITE_NATIVE_OUT_COORDINATE_SYSTEM_GRANULARITY_SPATIALITE_NATIVE_1 FEATURE_TYPE
SPATIALITE_NATIVE_1_COORDINATE_SYSTEM_GRANULARITY "$(SPATIALITE_NATIVE_OUT_COORDINATE_SYSTEM_GRANULARITY_SPATIALITE_NATIVE_1)"
# Compatibility case to support reading old workspaces with raw byte if unicode
DEFAULT_MACRO SPATIALITE_NATIVE_OUT_SUPPORT_INTERNATIONALIZATION_SPATIALITE_NATIVE_1 YES
SPATIALITE_NATIVE_1_SUPPORT_INTERNATIONALIZATION "$(SPATIALITE_NATIVE_OUT_SUPPORT_INTERNATIONALIZATION_SPATIALITE_NATIVE_1)"
DEFAULT_MACRO SPATIALITE_NATIVE_OUT_ENCODING_SPATIALITE_NATIVE_1 utf-8
SPATIALITE_NATIVE_1_ENCODING "$(SPATIALITE_NATIVE_OUT_ENCODING_SPATIALITE_NATIVE_1)"
# ============================================================================
SPATIALITE_NATIVE_1_GENERATE_FME_BUILD_NUM 26124
# ============================================================================
# The following specifies when we should perform table initialization.
# Table initialization is when we DROP, TRUNCATE, and CREATE TABLE.
DEFAULT_MACRO SPATIALITE_NATIVE_OUT_INIT_TABLES_SPATIALITE_NATIVE_1 FIRSTFEATURE
SPATIALITE_NATIVE_1_INIT_TABLES "$(SPATIALITE_NATIVE_OUT_INIT_TABLES_SPATIALITE_NATIVE_1)"
#! END_DEST_HEADER
#! START_WB_HEADER
DEFAULT_MACRO DestDataset
INCLUDE [ if {"$(DestDataset)" != ""} {                          \
 puts {DEFAULT_MACRO DestDataset_SPATIALITE_NATIVE_1 $(DestDataset)}         \
 } ]
#! END_WB_HEADER
#! START_DEST_HEADER SPATIALITE_NATIVE SPATIALITE_NATIVE_1
DEFAULT_MACRO DestDataset_SPATIALITE_NATIVE_1 $(DestDataset_SPATIALITE_NATIVE)
SPATIALITE_NATIVE_1_DATASET "$(DestDataset_SPATIALITE_NATIVE_1)"
#! END_DEST_HEADER
#! START_WB_HEADER
#! END_WB_HEADER
#! END_HEADER

LOG_FILENAME "$(FME_MF_DIR)$(WORKSPACE_NAME).log"
LOG_APPEND NO
LOG_MAX_FEATURES 200
LOG_MAX_RECORDED_FEATURES 200
FME_REPROJECTION_ENGINE FME
FME_IMPLICIT_CSMAP_REPROJECTION_MODE Auto
FME_GEOMETRY_HANDLING Enhanced
FME_STROKE_MAX_DEVIATION 0
FME_NAMES_ENCODING UTF-8
FME_BULK_MODE_THRESHOLD 2000
LAST_SAVE_BUILD "FME 2026.1.2.0 (20260512 - Build 26124 - WIN64)"
DEFAULT_MACRO DATASET_KEYWORD_SHAPEFILE_1 SHAPEFILE_1
DEFAULT_MACRO DATASET_KEYWORD_SPATIALITE_NATIVE_1 SPATIALITE_NATIVE_1
