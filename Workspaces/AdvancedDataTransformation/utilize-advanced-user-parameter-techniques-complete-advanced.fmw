# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   MULTI_READER_KEYWORD $(DATASET_KEYWORD_MITAB_1)   INPUT FEATURE_TYPE *    ROUTE MITAB MITAB_1::Parks multi_reader_keyword,$(DATASET_KEYWORD_MITAB_1) TO FME_GENERIC ::Parks ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
MITAB_1_MERGE_DEF MITAB_1::Parks EXACT Parks
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "Parks_MITAB_1 Splitter"    INPUT FEATURE_TYPE Parks    OUTPUT FEATURE_TYPE Parks_MITAB_1
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
Tcl2 proc Creator_CoordSysRemover {} {   global FME_CoordSys;   set FME_CoordSys {}; }
MACRO Creator_XML     NOT_ACTIVATED
MACRO Creator_GEOJSON NOT_ACTIVATED
MACRO Creator_NOGEOM NOT_ACTIVATED
INCLUDE [ if { {No Geometry} == {Geometry Object} } {            puts {MACRO Creator_XML *} } ]
INCLUDE [ if { {No Geometry} == {GeoJSON} } {            puts {MACRO Creator_GEOJSON *} } ]
INCLUDE [ if { {No Geometry} == {No Geometry} } {            puts {MACRO Creator_NOGEOM *} } ]
FACTORY_DEF {$(Creator_XML)} CreationFactory    FACTORY_NAME { Creator_XML_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(FROM_ENCODED_STRING,<Unused>) }
FACTORY_DEF {$(Creator_GEOJSON)} CreationFactory    FACTORY_NAME { Creator_GEOJSON_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @SupplyAttributes(ENCODED,__GeoJSONCreatorTemp__,<Unused>)        @JSONGeometry(FROM_ATTRIBUTE,GEOJSON,__GeoJSONCreatorTemp__, PREFER_ERROR_OVER_REJECTION)        @RemoveAttributes(__GeoJSONCreatorTemp__) }
FACTORY_DEF {$(Creator_NOGEOM)} CreationFactory    FACTORY_NAME { Creator_NOGEOM_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(CREATE_NO_GEOMETRY) }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Creator_Cloner }    INPUT FEATURE_TYPE _____CREATED______        @Tcl2(Creator_CoordSysRemover)        @CoordSys(<Unused>)    NUMBER_OF_COPIES { 1 }    COPY_NUMBER_ATTRIBUTE { "_creation_instance" }    OUTPUT { FEATURE_TYPE Creator_CREATED        fme_feature_type Creator         }
FACTORY_DEF * BranchingFactory   FACTORY_NAME "Creator_CREATED Brancher -1 28"   INPUT FEATURE_TYPE Creator_CREATED   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   INPUT FEATURE_TYPE *  OUTPUT FEATURE_TYPE *
# -------------------------------------------------------------------------
FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { AttributeManager }    INPUT  FEATURE_TYPE Parks_MITAB_1    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ACTION_COLUMN 4    DEF_VAL_COLUMN 2    NUM_OF_COLUMNS 5    MISSING_INPUT_ATTR_HANDLING RENAME_SET_VALUE REMOVE    ATTR_ACTION { "ParkId" "ParkId" "" "int16" "NO_OP" }      ATTR_ACTION { "ParkName" "ParkName" "" "varchar<openparen>40<closeparen>" "NO_OP" }      ATTR_ACTION { "NeighborhoodName" "Neighborhood" "" "varchar<openparen>40<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "DogPark" "DogPark" "" "varchar<openparen>1<closeparen>" "NO_OP" }      ATTR_ACTION { "VisitorCount" "VisitorCount" "" "int16" "NO_OP" }      ATTR_ACTION { "TreeCount" "TreeCount" "" "int16" "NO_OP" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeManager_OUTPUT        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester }    INPUT  FEATURE_TYPE AttributeManager_OUTPUT    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>DogPark<closeparen>,Tester)" = N ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,$(DogParks$encode),Tester)" = Yes ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    OUTPUT { PASSED FEATURE_TYPE Tester_PASSED         }    OUTPUT { FAILED FEATURE_TYPE Tester_FAILED         }
# -------------------------------------------------------------------------
INCLUDE [          if { ({Plane Area} == {Sloped Area}) } {             puts {MACRO AreaCalculator_func @Area(REJECTABLE,ALLOW_NULLS,SLOPED_AREAS,"1")};          } else {             puts {MACRO AreaCalculator_func @Area(REJECTABLE,ALLOW_NULLS,"1")};          }          ]
FACTORY_DEF {*} ExecuteFunctionFactory    FACTORY_NAME { AreaCalculator_AreaCalculator }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE Tester_PASSED    FUNCTION_DEFINITION { $(AreaCalculator_func) }    RESULT_ATTRIBUTE { "ParkArea" }    OUTPUT { COMPLETE FEATURE_TYPE AreaCalculator_OUTPUT        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} StatisticsCalculatorFactory    FACTORY_NAME { StatisticsCalculator }    INPUT  FEATURE_TYPE AreaCalculator_OUTPUT    GROUP_BY { Neighborhood }    FLUSH_WHEN_GROUPS_CHANGE { No }    STATISTIC_SUFFIX_RENAME_MAP { MEAN,AverageParkArea }    PREPEND_ATTR_NAME { No }    FEAT_STATS { ParkArea,NUMERIC_MODE,,,,,MEAN,,,,,,,, }    ADVANCED_MODE { NO }    CUMULATIVE_STATS {  }    CALCULATION_MODE { NUMERIC }    ATTR_ACCUM_MODE { None }    ATTRIBUTE_NAMES_AND_TYPES { ParkId,int16,ParkName,varchar<openparen>40<closeparen>,Neighborhood,varchar<openparen>40<closeparen>,DogPark,varchar<openparen>1<closeparen>,VisitorCount,int16,TreeCount,int16,ParkArea,real64 }    TREAT_INVALID_AS_NULL Yes    OUTPUT { COMPLETE FEATURE_TYPE StatisticsCalculator_COMPLETE        }
# -------------------------------------------------------------------------
Tcl2 proc AttributeRounder_round {places} {    set attrNames [split {AverageParkArea ParkArea} { }];    set funcName {round};    set parmList {{EvaluateExpression} {ATTR_SET_EXPR}};    set hasAttr 0;    foreach attrName $attrNames {       set decodedAttrName [FME_DecodeText $attrName];       set attrValue [FME_GetAttribute $decodedAttrName];       set comment {"--- skip null or missing attribute names without warning ---"};       if {$attrValue == {} || [FME_IsAttributeNull $decodedAttrName]} {          continue;       };       set comment {"--- do not round if the value is a string. warn skip the attribute ---"};       if {[string is double $attrValue] == 0} {          FME_LogMessage fme_warn 917360 {AttributeRounder} $decodedAttrName $attrValue;          continue;       };       set hasAttr 1;       set funcAttr $attrName;       set comment {"--- handle WWJD encoded attribute name embedded quote escaping ---"};       if { [string first "<quote>" $attrName] != -1 }       {          set funcAttr [string map {"<quote>" "<backslash><quote>"} $attrName];          append funcAttr "<quote>";          set funcAttr "<quote>"$funcAttr;       };       set comment {"--- build a WWJD string of: @round|ceil|floor(@Value(attrName),places) ---"};       set funcCall [join [list "<at>" $funcName "<openparen><at>Value<openparen>" $funcAttr "<closeparen><comma>" $places "<closeparen>"] {}];       lappend parmList $attrName;       lappend parmList $funcCall;    };    if {$hasAttr > 0} {       lappend parmList {AttributeRounder};       eval FME_Execute $parmList;    }; }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { AttributeRounder }    INPUT  FEATURE_TYPE StatisticsCalculator_COMPLETE    TEST { "@EvaluateExpression(FDIV,FLOAT,$(NumberRounding$encode),AttributeRounder)" TYPE INT ENCODED }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT { FAILED FEATURE_TYPE AttributeRounder_<REJECTED>       fme_rejection_code "INVALID_PARAMETER_DECIMAL_PLACES"        }    OUTPUT { PASSED FEATURE_TYPE __toOutput__ }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRounder_AttributeRounder }    INPUT FEATURE_TYPE __toOutput__    OUTPUT { FEATURE_TYPE AttributeRounder_OUTPUT         @Tcl2("AttributeRounder_round {@EvaluateExpression(FDIV,FLOAT,$(NumberRounding$encode),AttributeRounder)}")          }
FACTORY_DEF * TeeFactory   FACTORY_NAME "AttributeRounder OUTPUT Splitter"   INPUT FEATURE_TYPE AttributeRounder_OUTPUT   OUTPUT FEATURE_TYPE AttributeRounder_OUTPUT_0_4wUypaWBNbQ=   OUTPUT FEATURE_TYPE AttributeRounder_OUTPUT_1_mXyfxzDDDng=
FACTORY_DEF * TeeFactory   FACTORY_NAME "AttributeRounder <REJECTED> Splitter"   INPUT FEATURE_TYPE AttributeRounder_<REJECTED>   OUTPUT FEATURE_TYPE AttributeRounder_<REJECTED>_0_maaa2rUa2ng=   OUTPUT FEATURE_TYPE AttributeRounder_<REJECTED>_1_sDALLKd46O8=
# -------------------------------------------------------------------------
FACTORY_DEF {*} LabelFactory    FACTORY_NAME { LabelPointReplacer_Liner }    INPUT  FEATURE_TYPE AttributeRounder_OUTPUT_0_4wUypaWBNbQ=    INPUT  FEATURE_TYPE AttributeRounder_<REJECTED>_0_maaa2rUa2ng=    REJECT_INVALID_GEOM YES    TREAT_NONLINE_SPECIAL YES    PLACEMENT UPPER_RIGHT    PLACEMENT_DISTANCE 0    LABEL_ALWAYS_ROTATE { yes }    OUTPUT { POINT FEATURE_TYPE LabelPointReplacer_LabelPoint         @GeometryType(fme_text,"@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>$(LabelAttribute$encode)<closeparen>,LabelPointReplacer)","25",@Value(LabelRotation), ENCODED)          }    OUTPUT { REJECTED FEATURE_TYPE LabelPointReplacer_<REJECTED>          }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME LabelPointReplacer_<Rejected> INPUT FEATURE_TYPE LabelPointReplacer_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, LabelPointReplacer<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {Tester_Failed_5070c34e_aad3_4ba4_b85a_7064c988b1680} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME Tester_Failed
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Tester_Failed_Logger }    INPUT  FEATURE_TYPE Tester_FAILED    OUTPUT { FEATURE_TYPE Tester_Failed_LOGGED                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature<space>is:","20","20","",INFO,LOG_RECORD,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "Tester_Failed LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE Tester_Failed_LOGGED
