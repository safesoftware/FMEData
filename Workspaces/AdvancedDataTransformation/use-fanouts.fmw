OPENFILEGDB_1_MERGE_DEF OPENFILEGDB_1::FoodVendors GLOB * DEFLINE openfilegdb_type,geodb_point,openfilegdb_where_wwjd,,fme_attribute_reading,all,VendorID,smallint,VendorName,text<openparen>48<closeparen>,VendorDescription,text<openparen>16<closeparen>,OBJECTID,largeint,BookCount,int,CentreAddress,text<openparen>30<closeparen>,CentreName,text<openparen>30<closeparen>,CentreURL,text<openparen>50<closeparen>,Circulation,int,Description,text<openparen>75<closeparen>,FountainID,smallint,LibraryAddress,text<openparen>30<closeparen>,LibraryID,text<openparen>6<closeparen>,LibraryName,text<openparen>30<closeparen>,LibraryURL,text<openparen>80<closeparen>,Location,text<openparen>50<closeparen>,Maintainer,text<openparen>16<closeparen>,NumAddresses,smallint,ParkAddress,text<openparen>50<closeparen>,ParkName,text<openparen>30<closeparen>,ParkURL,text<openparen>100<closeparen>,Regulation,text<openparen>75<closeparen>,Schedule,text<openparen>30<closeparen>,StationName,text<openparen>30<closeparen>,Subzone,text<openparen>30<closeparen>,UserVisits,int,Zone,text<openparen>30<closeparen>
