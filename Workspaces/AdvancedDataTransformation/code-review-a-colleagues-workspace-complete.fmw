FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   MULTI_READER_KEYWORD $(DATASET_KEYWORD_OPENFILEGDB_1)   INPUT FEATURE_TYPE *    ROUTE OPENFILEGDB OPENFILEGDB_1::CommunityCentres multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::CommunityCentres ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::GarbageSchedule multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::GarbageSchedule ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::AccessibleParking multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::AccessibleParking ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::TransitStations multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::TransitStations ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::Libraries multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::Libraries ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::DrinkingFountains multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::DrinkingFountains ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::Parks multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::Parks ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::FoodVendors multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::FoodVendors ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
OPENFILEGDB_1_MERGE_DEF OPENFILEGDB_1::CommunityCentres EXACT CommunityCentres DEFLINE openfilegdb_type,geodb_point,openfilegdb_where_wwjd,,fme_attribute_reading,defined,CentreName,text<openparen>30<closeparen>,CentreAddress,text<openparen>30<closeparen>,CentreURL,text<openparen>50<closeparen>,OBJECTID,largeint
OPENFILEGDB_1_MERGE_DEF OPENFILEGDB_1::GarbageSchedule EXACT GarbageSchedule DEFLINE openfilegdb_type,geodb_polygon,openfilegdb_where_wwjd,,fme_attribute_reading,defined,Zone,text<openparen>30<closeparen>,Subzone,text<openparen>30<closeparen>,Schedule,text<openparen>30<closeparen>,NumAddresses,smallint,OBJECTID,largeint
OPENFILEGDB_1_MERGE_DEF OPENFILEGDB_1::AccessibleParking EXACT AccessibleParking DEFLINE openfilegdb_type,geodb_point,openfilegdb_where_wwjd,,fme_attribute_reading,defined,Description,text<openparen>75<closeparen>,Location,text<openparen>50<closeparen>,Regulation,text<openparen>75<closeparen>,OBJECTID,largeint
OPENFILEGDB_1_MERGE_DEF OPENFILEGDB_1::TransitStations EXACT TransitStations DEFLINE openfilegdb_type,geodb_point,openfilegdb_where_wwjd,,fme_attribute_reading,defined,StationName,text<openparen>30<closeparen>,OBJECTID,largeint
