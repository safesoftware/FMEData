OPENFILEGDB_1_DEF BusinessOwners   openfilegdb_type             geodb_point   fme_feature_operation        INSERT   fme_table_handling           CREATE_IF_MISSING   fme_selection_method         MATCH_ID   fme_match_id_attribute       OBJECTID   openfilegdb_target_arcgis_version ALL   openfilegdb_object_id_field  OBJECTID   openfilegdb_object_id_alias  OBJECTID   openfilegdb_shape_field      ""   openfilegdb_config_keyword   DEFAULTS   openfilegdb_xy_tolerance     ""   openfilegdb_z_tolerance      0.001   openfilegdb_m_tolerance      0.001   fme_constant_feature_type    YES   fme_geometry_name:SHAPE      spatial_type,   last_name                    text(10)   first_name                   text(11)   company                      text(40)   license_number               text(6)
