FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE OPENFILEGDB OPENFILEGDB_1::GarbageSchedule multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::GarbageSchedule ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
OPENFILEGDB_1_MERGE_DEF OPENFILEGDB_1::GarbageSchedule EXACT GarbageSchedule DEFLINE openfilegdb_type,geodb_polygon,openfilegdb_where_wwjd,,fme_attribute_reading,defined,Zone,text<openparen>30<closeparen>,Subzone,text<openparen>30<closeparen>,Schedule,text<openparen>30<closeparen>,NumAddresses,smallint,OBJECTID,largeint
POSTGIS_1_MERGE_DEF POSTGIS_1::public.PostalAddress EXACT public.PostalAddress
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "GarbageSchedule_OPENFILEGDB_1 Splitter"    INPUT FEATURE_TYPE GarbageSchedule    OUTPUT FEATURE_TYPE GarbageSchedule_OPENFILEGDB_1
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "public.PostalAddress_POSTGIS_1 Splitter"    INPUT FEATURE_TYPE public.PostalAddress    OUTPUT FEATURE_TYPE public.PostalAddress_POSTGIS_1
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
MACRO DatabaseQuerier_DIRECTIVES CREATE_FEATURE_TABLES_FROM_DATA Yes DISABLE_COLLECTION_SPLITTING yes NAMED_CONNECTION FME<space>Training<space>PostGIS<space>Database QUERY_FEATURE_TYPES_FOR_MERGE_FILTERS Yes READ_TIME_WITH_TIMEZONE Yes SCHEMAS_FOR_TABLE_LISTING "" USE_TRUE_POSTGIS_TYPES yes
INCLUDE [    if { {*} == {CONNECTED} } {       puts {MACRO SETTINGS_LINES  COMBINE_ATTRIBUTES RESULT_ONLY  COMBINE_GEOMETRY RESULT_ONLY};    } else {       puts {MACRO SETTINGS_LINES  COMBINE_ATTRIBUTES <Unused>  IGNORE_NULLS <Unused>  COMBINE_GEOMETRY <Unused>};    } ]
FACTORY_DEF {*} CreationFactory    FACTORY_NAME { DatabaseQuerier_Creator }    OUTPUT { FEATURE_TYPE DatabaseQuerier_____CREATED______ }
FACTORY_DEF {*} QueryFactory    FACTORY_NAME { DatabaseQuerier }    INPUT { FEATURE_TYPE DatabaseQuerier_____CREATED______ }    QUERY_SQL            { "@EvaluateExpression(FDIV,STRING_ENCODED,SELECT<space>*<space>FROM<space><quote>public<quote>.<quote>PostalAddress<quote><lf>WHERE<space><quote>AddressId<quote><space>=<space>$(AddressID$encode),DatabaseQuerier)" }    READER_TYPE          { POSTGIS }    READER_DATASET       { "FME<space>Training<space>PostGIS<space>Database" }    $(SETTINGS_LINES)    QUERYFCT_OUTPUT      { "DATA_ONLY" }    CONTINUE_ON_READER_ERROR YES    QUERYFCT_PROPAGATE_IDS_ON_SQL_EXECUTE YES    READER_PARAMS        { $(DatabaseQuerier_DIRECTIVES) }    TREAT_READER_PARAM_AMPERSANDS_AS_LITERALS YES    OUTPUT { RESULT FEATURE_TYPE DatabaseQuerier_RESULT        @SupplyAttributes(fme_feature_type,DatabaseQuerier)         }
FACTORY_DEF * BranchingFactory   FACTORY_NAME "DatabaseQuerier_RESULT Brancher -1 21"   INPUT FEATURE_TYPE DatabaseQuerier_RESULT   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   INPUT FEATURE_TYPE *  OUTPUT FEATURE_TYPE *
# -------------------------------------------------------------------------
FACTORY_DEF {*} OverlayFactory    FACTORY_NAME { PointOnAreaOverlayer }    INPUT POINT FEATURE_TYPE public.PostalAddress_POSTGIS_1    INPUT POINT FEATURE_TYPE DatabaseQuerier_RESULT    INPUT POLYGON FEATURE_TYPE GarbageSchedule_OPENFILEGDB_1    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    OVERLAP_COUNT_ATTRIBUTE { "_overlaps" }    DEAGGREGATE_INPUT { Yes }    MERGE_ATTRS { "YES" }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "ORIGINAL_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    LIST_NAME { "<Unused>" }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    CANDIDATE_LIST_NAME { "<Unused>" }    CANDIDATE_LIST_ATTRS_TO_INCLUDE { <Unused> }    CANDIDATE_LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MODE COMPLETE    OVERLAY_TYPE POINT_ON_AREA    POLYS_FIRST { "NO" }    REJECT_INVALID_GEOM YES    OUTPUT { POINT FEATURE_TYPE PointOnAreaOverlayer_POINT         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    INPUT  FEATURE_TYPE PointOnAreaOverlayer_POINT    OUTPUT { FEATURE_TYPE HTMLReportGenerator_PROCESSED       fme_html5_title "Garbage<space>Collection<space>Day"       fme_html5_config "HEADER{{TEXT;Garbage<space>Collection<space>Day;HEADER;H2;HEADER_ID;;ALIGNMENT;LEFT;COLOR;0<comma>0<comma>0}}HTML{{HTML;@EvaluateExpression(FDIV,STRING_ENCODED,<lt>h3<gt><lt>strong<gt>Property:<space><lt><solidus>strong<gt><at>Value<openparen>AddressId<closeparen><lt><solidus>h3<gt>,HTMLReportGenerator)}}HTML{{HTML;@EvaluateExpression(FDIV,STRING_ENCODED,<lt>h3<gt><lt>strong<gt>Address:<space><lt><solidus>strong<gt><at>Value<openparen>PostalAddress<closeparen><comma><space><at>Value<openparen>PostalCity<closeparen><lt><solidus>h3<gt>,HTMLReportGenerator)}}HTML{{HTML;@EvaluateExpression(FDIV,STRING_ENCODED,<lt>h3<gt><lt>strong<gt>Garbage<space>Zone:<space><lt><solidus>strong<gt><at>Value<openparen>Zone<closeparen><comma><space><at>Value<openparen>Subzone<closeparen><lt><solidus>h3<gt>,HTMLReportGenerator)}}HTML{{HTML;@EvaluateExpression(FDIV,STRING_ENCODED,<lt>h3<gt><lt>strong<gt>Collection<space>Day:<space><lt><solidus>strong<gt><at>Value<openparen>Schedule<closeparen><lt><solidus>h3<gt>,HTMLReportGenerator)"       fme_html5_xformer_name "HTMLReportGenerator" }
FACTORY_DEF {*} PythonFactory    FACTORY_NAME { HTMLReportGenerator }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT { FEATURE_TYPE HTMLReportGenerator_PROCESSED }    SYMBOL_NAME reportgenerator.html5assembler.HTML5Assembler    OUTPUT { PYOUTPUT FEATURE_TYPE HTMLReportGenerator_OUTPUT            }
# -------------------------------------------------------------------------
