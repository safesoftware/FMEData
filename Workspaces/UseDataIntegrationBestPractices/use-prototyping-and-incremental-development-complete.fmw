FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE SHAPEFILE SHAPEFILE_2::road-ahead-upcoming-projects multi_reader_keyword,$(DATASET_KEYWORD_SHAPEFILE_2) TO FME_GENERIC ::road-ahead-upcoming-projects ALIAS_GEOMETRY    ROUTE CSV2 CSV2_3::CSV multi_reader_keyword,$(DATASET_KEYWORD_CSV2_3) TO FME_GENERIC ::CSV ALIAS_GEOMETRY    ROUTE CSV2 CSV2_1::CSV multi_reader_keyword,$(DATASET_KEYWORD_CSV2_1) TO FME_GENERIC ::CSV ALIAS_GEOMETRY    ROUTE SQLITE3 SQLITE3_1::business-licences multi_reader_keyword,$(DATASET_KEYWORD_SQLITE3_1) TO FME_GENERIC ::business-licences ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
SHAPEFILE_2_MERGE_DEF SHAPEFILE_2::road-ahead-upcoming-projects EXACT road-ahead-upcoming-projects
CSV2_3_MERGE_DEF CSV2_3::CSV EXACT CSV DEFLINE fme_attribute_reading,defined,FOLDERYEAR,uint32,LicenceRSN,uint32,LicenceNumber,varchar<openparen>9<closeparen>,LicenceRevisionNumber,uint32,BusinessName,varchar<openparen>88<closeparen>,BusinessTradeName,varchar<openparen>76<closeparen>,Status,varchar<openparen>20<closeparen>,IssuedDate,varchar<openparen>25<closeparen>,ExpiredDate,varchar<openparen>10<closeparen>,BusinessType,varchar<openparen>40<closeparen>,BusinessSubType,varchar<openparen>34<closeparen>,Unit,varchar<openparen>10<closeparen>,UnitType,varchar<openparen>5<closeparen>,House,varchar<openparen>8<closeparen>,Street,varchar<openparen>20<closeparen>,City,varchar<openparen>9<closeparen>,Province,varchar<openparen>2<closeparen>,Country,varchar<openparen>2<closeparen>,PostalCode,varchar<openparen>10<closeparen>,LocalArea,varchar<openparen>24<closeparen>,NumberofEmployees,real32,FeePaid,uint32,ExtractDate,varchar<openparen>25<closeparen>,Geom,varchar<openparen>71<closeparen>
CSV2_1_MERGE_DEF CSV2_1::CSV EXACT CSV DEFLINE fme_attribute_reading,defined,KEY,varchar<openparen>4<closeparen>,VENDOR_TYPE,varchar<openparen>11<closeparen>,STATUS,varchar<openparen>4<closeparen>,BUSINESS_NAME,varchar<openparen>28<closeparen>,LOCATION,varchar<openparen>75<closeparen>,DESCRIPTION,varchar<openparen>34<closeparen>,GEO_LOCALAREA,varchar<openparen>24<closeparen>,x,real64,y,real64
SQLITE3_1_MERGE_DEF SQLITE3_1::business-licences EXACT business-licences DEFLINE sqlite3_sql_statement,,sqlite3_where_clause,,fme_attribute_reading,defined,FOLDERYEAR,integer,LicenceRSN,integer,LicenceNumber,varchar<openparen>10<closeparen>,LicenceRevisionNumber,integer,BusinessName,varchar<openparen>89<closeparen>,BusinessTradeName,varchar<openparen>77<closeparen>,Status,varchar<openparen>21<closeparen>,IssuedDate,varchar<openparen>26<closeparen>,ExpiredDate,varchar<openparen>11<closeparen>,BusinessType,varchar<openparen>41<closeparen>,BusinessSubType,varchar<openparen>35<closeparen>,Unit,varchar<openparen>11<closeparen>,UnitType,varchar<openparen>6<closeparen>,House,varchar<openparen>9<closeparen>,Street,varchar<openparen>21<closeparen>,City,varchar<openparen>10<closeparen>,Province,varchar<openparen>3<closeparen>,Country,varchar<openparen>3<closeparen>,PostalCode,varchar<openparen>11<closeparen>,LocalArea,varchar<openparen>25<closeparen>,NumberofEmployees,float,FeePaid,integer,ExtractDate,varchar<openparen>26<closeparen>,Geom,varchar<openparen>72<closeparen>
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "road-ahead-upcoming-projects_SHAPEFILE_2 Splitter"    INPUT FEATURE_TYPE road-ahead-upcoming-projects    OUTPUT FEATURE_TYPE road-ahead-upcoming-projects_SHAPEFILE_2
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "business-licences_SQLITE3_1 Splitter"    INPUT FEATURE_TYPE business-licences    OUTPUT FEATURE_TYPE business-licences_SQLITE3_1
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "CSV_CSV2_3 Splitter"    INPUT FEATURE_TYPE CSV      multi_reader_keyword $(DATASET_KEYWORD_CSV2_3)
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "CSV_CSV2_1 Splitter"    INPUT FEATURE_TYPE CSV      multi_reader_keyword $(DATASET_KEYWORD_CSV2_1)    OUTPUT FEATURE_TYPE CSV_CSV2_1
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester }    INPUT  FEATURE_TYPE business-licences_SQLITE3_1    TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>FOLDERYEAR<closeparen>,Tester)" = 21 ENCODED } TEST { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>Status<closeparen>,Tester)" != Gone<space>Out<space>of<space>Business ENCODED }    BOOLEAN_OPERATOR { COMPOSITE }    COMPOSITE_TEST_EXPR { "1 AND 2" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE Tester_PASSED         }
# -------------------------------------------------------------------------
MACRO testClauses #Tcl to generate test clauses for the table in preparation for the TestFactory
#Each Attribute gets put in a seperate clause
INCLUDE [    set table {KEY$ATTRIBUTE_UNIQUE$<Unused>/BUSINESS_NAME$ATTRIBUTE_HAS_A_VALUE$<Unused>};    set testString {MACRO testClauses };    set rows [split $table {/}];    foreach row $rows {    set cells [split $row {$}];    set attrs [split [lindex $cells 0] {,}];       set op [lindex $cells 1];       set val [lindex $cells 2];       foreach attr $attrs {           append testString "TEST \{ ${attr} ${op} ${val} ENCODED \} ";       };    };    puts $testString;    ]
FACTORY_DEF {*} TestFactory    FACTORY_NAME { AttributeValidator }    INPUT  FEATURE_TYPE CSV_CSV2_1    $(testClauses)    BOOLEAN_OPERATOR AND    VALIDATOR_MODE TRUE    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE AttributeValidator_PASSED         }
# -------------------------------------------------------------------------
# 20210313 - Use Macros to engage/disengage the solid vs. 2d buffering rather than a runtime
# check to reduce processing overhead
INCLUDE [if { ("JOIN_ARC" == "JOIN_MITER") } {         } else {             puts "MACRO MITER_TO_USE 0"         };         if { ("AREA" == "SOLID") } {             puts "MACRO SOLIDFACTORYENGAGED *";             puts "MACRO DISSOLVEFACTORYENGAGED NO";         } else {             puts "MACRO SOLIDFACTORYENGAGED NO";             puts "MACRO DISSOLVEFACTORYENGAGED *";         };         ]
#
# This is the AREA part of the buffering:
#
FACTORY_DEF {$(DISSOLVEFACTORYENGAGED)} PolygonDissolveFactory    FACTORY_NAME { Bufferer_2DBuffering }    INPUT  FEATURE_TYPE road-ahead-upcoming-projects_SHAPEFILE_2    FLUSH_WHEN_GROUPS_CHANGE { No }    REJECT_INVALID_GEOM Yes    USE_AZMED_NEIGHBORHOOD Yes    PRE_BUFFER { "50" "22.5" "CAP_ARC" "JOIN_ARC" "$(MITER_TO_USE)" FULL OFFSET_UNITS "FEET" PRECISION "APPROX" }    DISSOLVE_MODE GEOS    CLEANING_TOLERANCE { AUTO }    LIST_ATTRS_TO_INCLUDE { <Unused> }    LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    OUTPUT { POLYGON FEATURE_TYPE Bufferer_BUFFERED         }    OUTPUT { NON_POLYGON FEATURE_TYPE Bufferer_BUFFERED         }
#
# This is the SOLID part of the buffering:
#
FACTORY_DEF {$(SOLIDFACTORYENGAGED)} SolidBufferingFactory    FACTORY_NAME { Bufferer_3DBuffering }    INPUT  FEATURE_TYPE road-ahead-upcoming-projects_SHAPEFILE_2    SPHERE_RADIUS { "50" }    SPHERE_DIVISIONS { "<Unused>" }    OUTPUT { BUFFERED FEATURE_TYPE Bufferer_BUFFERED        }
# -------------------------------------------------------------------------
FACTORY_DEF {*} SpatialFilterFactory    FACTORY_NAME { SpatialFilter }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT BASE FEATURE_TYPE Bufferer_BUFFERED    INPUT CANDIDATE FEATURE_TYPE AttributeValidator_PASSED    PRESERVE_FEATURE_ORDER { ACROSS_OUTPUT_PORTS }    PREDICATE { "INTERSECTS" }    USE_BOUNDING_BOX { NO }    MULTIPLE_BASES { YES }    MERGE_BASE_ATTR { YES }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "CANDIDATE_IF_CONFLICT" }    BASE_ATTR_PREFIX { "<Unused>" }    PREDICATE_ATTR { "_predicate" }    BOOLEAN_OPERATOR { OR }    REJECT_INVALID_GEOM Yes    REJECT_INVALID_PREDICATES Yes    REJECT_RASTERS No    REJECT_IGNORED_FILTER_FEATURES Yes    ALLOW_NULLS Yes    CUSTOM_MULTI_HANDLING { Yes }    DIMENSION 2    FLUSH_WHEN_GROUPS_CHANGE { <Unused>  }    CURVE_BOUNDARY_RULE { ENDPOINTS_MOD2 }    OUTPUT { PASSED FEATURE_TYPE SpatialFilter_PASSED         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} FeatureJoinerFactory    FACTORY_NAME { FeatureJoiner }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    INPUT LEFT FEATURE_TYPE SpatialFilter_PASSED    INPUT RIGHT FEATURE_TYPE Tester_PASSED    JOIN_MODE { Inner }    JOIN_KEYS { BUSINESS_NAME BusinessTradeName AUTO }    ATTR_CONFLICT_RES { USE_LEFT }    PRESERVE_VALUES_FROM_UNJOINED_FEATURES { YES }    GEOMETRY_HANDLING { USE_LEFT }    OUTPUT { JOINED FEATURE_TYPE FeatureJoiner_JOINED        }
