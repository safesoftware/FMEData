SHAPEFILE_2_EXPOSE_ATTRS_GROUP "$(SHAPEFILE_IN_EXPOSE_ATTRS_GROUP_SHAPEFILE_2)"
DEFAULT_MACRO SHAPEFILE_IN_SPATIAL_GROUP_SHAPEFILE_2 
GUI OPTIONAL DISCLOSUREGROUP SHAPEFILE_IN_SPATIAL_GROUP_SHAPEFILE_2 SHAPEFILE_IN_COORDINATE_SYSTEM_SHAPEFILE_2%SHAPEFILE_IN_DONUT_DETECTION_SHAPEFILE_2%SHAPEFILE_IN_MEASURES_AS_Z_SHAPEFILE_2%SHAPEFILE_IN_REPORT_BAD_GEOMETRY_SHAPEFILE_2%SHAPEFILE_IN_USE_SEARCH_ENVELOPE_SHAPEFILE_2 Spatial
