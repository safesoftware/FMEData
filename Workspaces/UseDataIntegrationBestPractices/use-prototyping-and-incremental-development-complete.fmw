FACTORY_DEF {*} AttrSetFactory    COMMAND_PARM_EVALUATION SINGLE_PASS    FACTORY_NAME { AttributeManager }    INPUT  FEATURE_TYPE FeatureJoiner_JOINED    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    ACTION_COLUMN 4    DEF_VAL_COLUMN 2    NUM_OF_COLUMNS 5    MISSING_INPUT_ATTR_HANDLING RENAME_SET_VALUE REMOVE    ATTR_ACTION { "BUSINESS_NAME" "Business<space>Name" "" "varchar<openparen>29<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "VENDOR_TYPE" "VENDOR_TYPE" "" "varchar<openparen>12<closeparen>" "REMOVE" }      ATTR_ACTION { "DESCRIPTION" "Description" "" "varchar<openparen>35<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "LOCATION" "Location" "" "varchar<openparen>76<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "STATUS" "Status" "" "varchar<openparen>5<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "project" "Street<space>Project" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "street" "Street" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "location" "Location" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "comp_date" "Completion<space>Date" "" "date" "RENAME_SET_VALUE" }      ATTR_ACTION { "url_link" "Project<space>Information<space>Link" "" "char<openparen>255<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "KEY" "KEY" "" "varchar<openparen>5<closeparen>" "REMOVE" }      ATTR_ACTION { "GEO_LOCALAREA" "GEO_LOCALAREA" "" "varchar<openparen>25<closeparen>" "REMOVE" }      ATTR_ACTION { "_predicate" "_predicate" "" "buffer" "REMOVE" }      ATTR_ACTION { "FOLDERYEAR" "FOLDERYEAR" "" "uint32" "REMOVE" }      ATTR_ACTION { "LicenceRSN" "LicenceRSN" "" "uint32" "REMOVE" }      ATTR_ACTION { "LicenceNumber" "Business<space>License<space>Number" "" "varchar<openparen>10<closeparen>" "RENAME_SET_VALUE" }      ATTR_ACTION { "LicenceRevisionNumber" "LicenceRevisionNumber" "" "uint32" "REMOVE