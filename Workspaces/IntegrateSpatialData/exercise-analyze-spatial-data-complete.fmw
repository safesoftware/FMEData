# -------------------------------------------------------------------------
FACTORY_DEF {*} OverlayFactory    FACTORY_NAME { PointOnAreaOverlayer }    INPUT POINT FEATURE_TYPE PostalAddress_OPENFILEGDB_1    INPUT POLYGON FEATURE_TYPE Clipper_INSIDE    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    OVERLAP_COUNT_ATTRIBUTE { "_overlaps" }    DEAGGREGATE_INPUT { Yes }    MERGE_ATTRS { "YES" }    ATTR_ACCUM_MODE { "HANDLE_CONFLICT" }    ATTR_CONFLICT_RES { "ORIGINAL_IF_CONFLICT" }    INCOMING_PREFIX { "<Unused>" }    LIST_NAME { "DistanceList" }    LIST_ATTRS_TO_INCLUDE { Distance }    LIST_ATTRS_TO_INCLUDE_MODE { SELECTED }    CANDIDATE_LIST_NAME { "<Unused>" }    CANDIDATE_LIST_ATTRS_TO_INCLUDE { <Unused> }    CANDIDATE_LIST_ATTRS_TO_INCLUDE_MODE { <Unused> }    MODE COMPLETE    OVERLAY_TYPE POINT_ON_AREA    POLYS_FIRST { "NO" }    REJECT_INVALID_GEOM YES    OUTPUT { POINT FEATURE_TYPE PointOnAreaOverlayer_POINT         }
# -------------------------------------------------------------------------
Tcl2 proc ListSorter_sort {} {    set COMMENT {    = NOTE: algorithm below does not support nested lists.    };    regsub \"{}.*$\" {DistanceList{}.Distance} \"\{\" listBase;    regsub \"{}.*$\" {DistanceList{}.Distance} \"\" listName;    set listBaseLen [string length $listBase];    set listNameLen [expr $listBaseLen - 1];    set listValueExtension [string replace {DistanceList{}.Distance} 0 $listBaseLen {}];    set kCloseBrace \"\}\";    set kAnyOtherCharacters {*};    set kPlaceholderMissingVal 1;    set kPlaceholderNullVal 2;    set kPlaceholderEmptyVal 3;    set COMMENT {    = To resolve PR 46315 (and friends), lets make a first pass to determine the full list of    = possible index numbers. Then we'll go through and make sure we have a KEY value for each    = of those.  We'll track what "keys" we added so that at the end we can REMOVE them so they stay MISSING.    };    set maxElementCount 0;    foreach attr [FME_AttributeNames] {       set COMMENT {       =    For each attribute "listattr{<index>}.count" and all related attributes       =    "listattr{<index>}<extension>", create a list of the form       =       {$listattr{<index>}.count <index>}, and keep a list of the extensions       =    for each index in the associative array listExtensions(<index>).       };       set attrStart [string range $attr 0 $listNameLen];       if { $attrStart == $listBase } {          set braceEnd [string first \} $attr $listBaseLen];          set index [string range $attr $listBaseLen [expr $braceEnd - 1]];          set extension [string range $attr [expr $braceEnd + 1] end];          if { [regexp {^[0-9]+$} $index] == 1 } {             lappend listExtensions($index) $extension;             set attrsToRename($attr) 1;             set COMMENT {Keep track of the maximum index value};             if { [expr $index > $maxElementCount] } {                set maxElementCount $index;             }          };       }    };    set curElement 0;    set COMMENT {    = Now that we have a list of the actual element numbers included in the list. Lets whip through and make sure    = we have an actual element for each of the "key" parts of the list we want to sort. If we don't, we'll    = make an element there with an empty value.  Note that we can't easily separate and sort NULL < missing < empty,    = but we'll live with that shortcoming in here as long as it is documented.    };    catch {unset emptyPlaceholder};    set toSort {};    set placeholdersToSort {};    foreach curElement [lsort -integer -unique [array names listExtensions]] {       set COMMENT {       =    We found that there is at least some kind of element at this index in the list       =    so we need to ensure there is a key element at this index. If it is missing,       =    NULL or an empty string, then we save it to a separate array of placehoder values of 1, 2 or       =    3, respectively, so that can be deterministically sorted separately from the other       =    elements, and then tacked on at either the beginning of the end later on.       };       set COMMENT {Minimum float is taken from std::numeric_limits<T>::lowest() cppreference web page.};       set indexKeyElementAttr $listBase$curElement$kCloseBrace$listValueExtension;       if { ! [FME_AttributeExists $indexKeyElementAttr ] } {           set COMMENT {The key value attribute didn't exist, so put it on a separate placeholder list for sorting};           lappend placeholdersToSort [list $kPlaceholderMissingVal $curElement];           set emptyPlaceholder($curElement) $kPlaceholderMissingVal;       } elseif { [FME_IsAttributeNull $indexKeyElementAttr] } {           set COMMENT {Key attribute exists but is null, so put it on a separate placeholder list for sorting};           set emptyPlaceholder($curElement) $kPlaceholderNullVal;           lappend placeholdersToSort [list $kPlaceholderNullVal $curElement];       } elseif { [FME_GetAttribute $indexKeyElementAttr] == {} } {           set COMMENT {Key attribute exists but is empty, so put it on a separate placeholder list for sorting};           set emptyPlaceholder($curElement) $kPlaceholderEmptyVal;           lappend placeholdersToSort [list $kPlaceholderEmptyVal $curElement];       } else {           lappend toSort [list [FME_GetAttribute $indexKeyElementAttr] $curElement]       };    };    set COMMENT {    =    Sort the {$listattr{<index>} <index>} by index 0 (attr value). If we had (1,2,3) placeholders    =    for missing, NULL, or empty values, we sort those as well, and then tack them onto the    =    proper end of the resulting list.    };    set sortedAttrs [lsort -real  -index 0 $toSort];    set sortedPlaceholders [lsort -real  -index 0 $placeholdersToSort];    set COMMMENT {    =    If there were placeholders for null/missing/empty, put them at the beginning    =    or end of the sortedAttrs, depending on sort order    };    if { {} != {} } {       set sortedAttrs [concat $sortedAttrs $sortedPlaceholders];    } else {       set sortedAttrs [concat $sortedPlaceholders $sortedAttrs];    };    set destIndex 0;    set COMMENT {    =    For each list within sortedAttrs, iterate over the list, renaming    =    "listattr{<index>}<extension>" to    =    "listattr{<newIndex>}<extension>"    };    catch {unset nullRemap};    set renameAttrsFrom {};    set renameAttrsTo {};    foreach pair $sortedAttrs {       set elementNum [lindex $pair 1];       set nullRemap($destIndex) $elementNum;       set newAttrBase "$listName\{$destIndex\}";       set oldAttrBase "$listName\{$elementNum\}";       foreach extension $listExtensions($elementNum) {          lappend renameAttrsFrom $oldAttrBase$extension;          lappend renameAttrsTo $newAttrBase$extension;          unset attrsToRename($oldAttrBase$extension);       };       incr destIndex    };    set COMMENT {    =    If any attributes were list attributes but did not contain the    =    structure extension on which we were sorting, they must be cleaned up.    };    set attrs [array names attrsToRename];    if {[llength $attrs]} { eval FME_UnsetAttributes $attrs };    FME_RenameAttribute -list $renameAttrsTo $renameAttrsFrom;    set COMMENT {    =    = Lastly, go through and any of the MISSING, EMPTY, or NULL key values and set appropriately.  We'll have preserved their    = parallel list structure friends, but we need to restore the moved key to its original state: missing, blank or NULL    =    };    set curElement 0;    while { $curElement <= $maxElementCount } {        if { [info exists nullRemap($curElement)] } {            set origIndex $nullRemap($curElement);            if { [info exists emptyPlaceholder($origIndex)] } {                set COMMENT {Get rid of the sidecar attribute and key attribute too};                set indexKeyElementAttr $listBase$curElement$kCloseBrace$listValueExtension;                set value $emptyPlaceholder($origIndex);                if {$value == $kPlaceholderNullVal} {                  FME_SetAttributeNull $indexKeyElementAttr;                } elseif { $value == $kPlaceholderMissingVal } {                    FME_UnsetAttributes $indexKeyElementAttr;                } else {                  FME_SetAttribute $indexKeyElementAttr {};                };             };        };        incr curElement;    }; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { ListSorter }    INPUT  FEATURE_TYPE PointOnAreaOverlayer_POINT    OUTPUT { FEATURE_TYPE ListSorter_OUTPUT         @Tcl2("ListSorter_sort")          }
# -------------------------------------------------------------------------
Tcl2 proc ListIndexer_indexer {index numElements prefix suffix} {    if {$index < 0 } {       set index [expr $numElements + $index];    };    regsub \"{}\" {DistanceList{}} \"{$index}\" listWithIndex;    regsub \"{}\" {DistanceList{}} {} listBase;    set complexListExp "$listWithIndex\.";    set prefixLength [expr [string length $complexListExp]-1];    set prefix [FME_DecodeText $prefix];    set suffix [FME_DecodeText $suffix];    foreach attr [FME_AttributeNames] {      set newAttr {};      if {$attr == $listWithIndex} {        set newAttr $listBase;      } elseif {[string first $complexListExp $attr] == 0} {        set newAttr [string replace $attr 0 $prefixLength];      };      if {$newAttr != {}} {          if {$prefix != {} } {            set newAttr $prefix$newAttr;          };          if {$suffix != {} } {            set newAttr $newAttr$suffix;          };          if {[string first {fme_} $newAttr] != 0} {              set first [string first {fme_} $newAttr];              lappend attrsToCopy $newAttr $attr;          };      };    };    if {[info exists attrsToCopy] && [llength $attrsToCopy] > 0} {      eval FME_Execute CopyAttributes $attrsToCopy;    }; }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListIndexer_IntTester }    INPUT  FEATURE_TYPE ListSorter_OUTPUT    TEST { "0" TYPE INT ENCODED }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT { PASSED FEATURE_TYPE __toOutput__ }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { ListIndexer_ListIndexer }    INPUT FEATURE_TYPE __toOutput__    TEST { "0" >= 0 }    OUTPUT PASSED FEATURE_TYPE ListIndexer_OUTPUT @Tcl2("ListIndexer_indexer 0 0 {} {}")    OUTPUT FAILED FEATURE_TYPE ListIndexer_OUTPUT @Tcl2("ListIndexer_indexer 0 @NumElements(DistanceList{}) {} {}")
# -------------------------------------------------------------------------
FACTORY_DEF {*} TestFactory    FACTORY_NAME { Tester }    INPUT  FEATURE_TYPE ListIndexer_OUTPUT    TEST { Distance ATTRIBUTE_HAS_A_VALUE "" ENCODED }    BOOLEAN_OPERATOR { OR }    COMPOSITE_TEST_EXPR { "<Unused>" }    PRESERVE_FEATURE_ORDER { PER_OUTPUT_PORT }    OUTPUT { PASSED FEATURE_TYPE Tester_PASSED         }
