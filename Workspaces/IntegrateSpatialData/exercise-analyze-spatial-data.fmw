FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE CDED CDED_2::CDED multi_reader_keyword,$(DATASET_KEYWORD_CDED_2) TO FME_GENERIC ::CDED ALIAS_GEOMETRY    ROUTE OPENFILEGDB OPENFILEGDB_1::PostalAddress multi_reader_keyword,$(DATASET_KEYWORD_OPENFILEGDB_1) TO FME_GENERIC ::PostalAddress ALIAS_GEOMETRY    ROUTE SHAPEFILE SHAPEFILE_2::VancouverLandBoundary multi_reader_keyword,$(DATASET_KEYWORD_SHAPEFILE_2) TO FME_GENERIC ::VancouverLandBoundary ALIAS_GEOMETRY    ROUTE GML GML_2::Coastline multi_reader_keyword,$(DATASET_KEYWORD_GML_2) TO FME_GENERIC ::Coastline ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
CDED_2_MERGE_DEF CDED_2::CDED EXACT CDED
OPENFILEGDB_1_MERGE_DEF OPENFILEGDB_1::PostalAddress EXACT PostalAddress DEFLINE openfilegdb_type,geodb_point,openfilegdb_where_wwjd,,fme_attribute_reading,defined,GlobalID,guid,OWNERNM1,text<openparen>150<closeparen>,OWNERNM2,text<openparen>150<closeparen>,PSTLADDRESS,text<openparen>250<closeparen>,PSTLCITY,text<openparen>100<closeparen>,PSTLPROV,text<openparen>25<closeparen>,INTSTATE,text<openparen>5<closeparen>,INTPSTLCD,text<openparen>10<closeparen>,COUNTRY,text<openparen>100<closeparen>,REPRESENT,text<openparen>14<closeparen>,STATUS,text<openparen>9<closeparen>,LASTUPDATE,datetime,LASTEDITOR,text<openparen>50<closeparen>,POSTALCODE,text<openparen>6<closeparen>,OBJECTID,largeint
SHAPEFILE_2_MERGE_DEF SHAPEFILE_2::VancouverLandBoundary EXACT VancouverLandBoundary
GML_2_MERGE_DEF GML_2::Coastline EXACT Coastline
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "PostalAddress_OPENFILEGDB_1 Splitter"    INPUT FEATURE_TYPE PostalAddress
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "CDED_CDED_2 Splitter"    INPUT FEATURE_TYPE CDED    OUTPUT FEATURE_TYPE CDED_CDED_2
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "VancouverLandBoundary_SHAPEFILE_2 Splitter"    INPUT FEATURE_TYPE VancouverLandBoundary
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory    FACTORY_NAME "Coastline_GML_2 Splitter"    INPUT FEATURE_TYPE Coastline
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
FACTORY_DEF {*} ReprojectFactory    FACTORY_NAME { Reprojector }    INPUT  FEATURE_TYPE CDED_CDED_2    ENGINE { SOURCE "" DESTINATION "UTM83-10" }    INTERPOLATION_TYPE { NearestNeighbor }    RASTER_CELL_SIZE { PreserveCells }    RASTER_TOLERANCE { "0.0" }
# -------------------------------------------------------------------------

FACTORY_DEF * RoutingFactory FACTORY_NAME "Destination Feature Type Routing Correlator"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *   FEATURE_TYPE_ATTRIBUTE __wb_out_feat_type__   OUTPUT ROUTED FEATURE_TYPE *    OUTPUT NOT_ROUTED FEATURE_TYPE __nuke_me__ @Tcl2("FME_StatMessage 818059 [FME_GetAttribute fme_template_feature_type] 818060 818061 fme_warn")
# -------------------------------------------------------------------------

FACTORY_DEF * TeeFactory   FACTORY_NAME "Final Output Nuker"   INPUT FEATURE_TYPE __nuke_me__

